// cargo-pup inward-dependency rule: the version domain core may import only
// std / its own subtree / the shared kernel error taxonomy — never an
// adapter/infrastructure module. Width kept <= 80 columns per the
// hand-duplication convention.
//
// Note `matches` is the RESOLVED module path; `allowed_only` is LITERAL
// use-path.
(
    lints: [
        Module((
            name: "version_core_imports_only_permitted",
            matches: Module("^accelerator::version::core($|::)"),
            rules: [
                RestrictImports(
                    allowed_only: Some([
                        "^(std|core|alloc)(::|$)",
                        "^kernel::Error(::|$)",
                        "^crate::version::core(::|$)",
                    ]),
                    denied: None,
                    severity: Error,
                ),
            ],
        )),
        Module((
            name: "launch_core_imports_only_permitted",
            matches: Module("^accelerator::launch::core($|::)"),
            rules: [
                RestrictImports(
                    allowed_only: Some([
                        "^(std|core|alloc)(::|$)",
                        "^kernel::Error(::|$)",
                        "^crate::launch::core(::|$)",
                    ]),
                    denied: None,
                    severity: Error,
                ),
            ],
        )),
        // The whole config crate is domain (no adapter modules live in it), so
        // the rule matches the crate root rather than enumerating module names.
        Module((
            name: "config_domain_imports_only_permitted",
            matches: Module("^config($|::)"),
            rules: [
                RestrictImports(
                    allowed_only: Some([
                        "^(std|core|alloc)(::|$)",
                        "^kernel::Error(::|$)",
                        "^crate(::|$)",
                    ]),
                    denied: None,
                    severity: Error,
                ),
            ],
        )),
        // The whole corpus crate is domain (no adapter modules live in it).
        Module((
            name: "corpus_domain_imports_only_permitted",
            matches: Module("^corpus($|::)"),
            rules: [
                RestrictImports(
                    allowed_only: Some([
                        "^(std|core|alloc)(::|$)",
                        "^kernel::Error(::|$)",
                        "^crate(::|$)",
                    ]),
                    denied: None,
                    severity: Error,
                ),
            ],
        )),
        // The whole vcs crate is domain (no adapter modules live in it); the
        // filesystem walk and the subprocess probe live in vcs-adapters.
        Module((
            name: "vcs_domain_imports_only_permitted",
            matches: Module("^vcs($|::)"),
            rules: [
                RestrictImports(
                    allowed_only: Some([
                        "^(std|core|alloc)(::|$)",
                        "^kernel::Error(::|$)",
                        "^crate(::|$)",
                    ]),
                    denied: None,
                    severity: Error,
                ),
            ],
        )),
        // The config command's inbound hexagon must not reach the composition
        // root's adapter crate (`config_adapters`) nor a sibling launcher
        // module (`crate::launch`), so the injected-ports seam cannot erode.
        // Expressed as a `denied` list rather than `allowed_only`: cargo-pup
        // resolves a grouped `use config::{a, b}` to an empty module name,
        // which an `allowed_only` rule would reject as unpermitted — false-
        // positiving every legitimate grouped import the codebase uses. A
        // `denied` list is unaffected by that resolution and states the seam
        // prohibition directly.
        Module((
            name: "config_command_may_not_import_adapters_or_launch",
            matches: Module("^accelerator::config_command($|::)"),
            rules: [
                RestrictImports(
                    allowed_only: None,
                    denied: Some([
                        "^config_adapters(::|$)",
                        "^crate::launch(::|$)",
                    ]),
                    severity: Error,
                ),
            ],
        )),
    ],
)
