// cargo-pup inward-dependency rule (ADR-0053): a domain module may import only
// std / its own subtree — never an adapter/infrastructure module. Width kept
// <= 80 columns per the hand-duplication convention.
//
// The accelerator hexagon (domain / adapters modules) lands with the scaffold
// story; until then `launcher::domain` matches no module, so this pass is
// near-vacuous. The rule's discriminating power is proven by the fixture
// regression in tests/integration/pup/, not by the minimal scaffold.
//
// Note `matches` is the RESOLVED module path; `allowed_only` is LITERAL
// use-path.
(
    lints: [
        Module((
            name: "domain_imports_only_permitted",
            matches: Module("^launcher::domain($|::)"),
            rules: [
                RestrictImports(
                    allowed_only: Some([
                        "^(std|core|alloc)(::|$)",
                        "^crate::domain(::|$)",
                    ]),
                    denied: None,
                    severity: Error,
                ),
            ],
        )),
    ],
)
