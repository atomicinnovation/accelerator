#!/usr/bin/env bash
#
# bin/accelerator — the plugin entry point. On first use it fetches the
# accelerator launcher, verifies its minisign signature against the committed
# public key via the vendored per-triple shim (a binary cannot verify itself),
# caches it, and execs it; thereafter it re-verifies the cache and reuses it.
# Fail-closed throughout. Bash 3.2 floor (no associative arrays, ${var,,},
# mapfile).
#
# Test seams (unset in production): ACCELERATOR_UNAME_S/_M override host
# detection; ACCELERATOR_BOOTSTRAP_DOWNLOADER injects a `downloader <url> <dest>`.
#
# Local-build override (contributor-only): with ACCELERATOR_ALLOW_UNVERIFIED_LAUNCHER=1,
# the untracked .accelerator-dev-launcher marker, and ACCELERATOR_LAUNCHER_BIN
# naming a binary inside cli/target/, execs that launcher directly. Documented
# apart from the seams above because it bypasses the whole verification chain
# rather than substituting one step.
set -uo pipefail

fail() {
	printf 'accelerator: %s\n' "$1" >&2
	exit 1
}

[[ -n "${CLAUDE_PLUGIN_ROOT:-}" ]] || fail "CLAUDE_PLUGIN_ROOT is not set"
[[ -d "${CLAUDE_PLUGIN_ROOT}" ]] ||
	fail "CLAUDE_PLUGIN_ROOT is not a directory: ${CLAUDE_PLUGIN_ROOT}"

# The case arms must stay in sync with tasks/shared/targets.py (coherence test).
host_arch="${ACCELERATOR_UNAME_M:-$(uname -m)}"
host_os="${ACCELERATOR_UNAME_S:-$(uname -s)}"
case "${host_arch}" in
arm64 | aarch64) arch_alias=arm64 ;;
x86_64 | amd64) arch_alias=x64 ;;
*) fail "unsupported architecture: ${host_arch}" ;;
esac
case "${host_os}" in
Darwin) os_alias=darwin ;;
Linux) os_alias=linux ;;
*) fail "unsupported operating system: ${host_os}" ;;
esac
platform="${os_alias}-${arch_alias}"

plugin_json="${CLAUDE_PLUGIN_ROOT}/.claude-plugin/plugin.json"
[[ -f "${plugin_json}" ]] || fail "plugin.json not found: ${plugin_json}"
version=$(sed -n \
	's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "${plugin_json}")
version=${version%%$'\n'*}
[[ -n "${version}" ]] || fail "could not read version from plugin.json"

# The launcher is fetched before any Rust verification exists, so the transport
# is hardened: https pinned, bounded redirects/size/time, cert check never off.
if [[ -n "${ACCELERATOR_BOOTSTRAP_DOWNLOADER:-}" ]]; then
	fetch() { "${ACCELERATOR_BOOTSTRAP_DOWNLOADER}" "$1" "$2"; }
elif command -v curl >/dev/null 2>&1; then
	fetch() {
		curl --proto '=https' --tlsv1.2 --fail --silent --show-error \
			--location --max-redirs 10 --max-filesize 268435456 \
			--connect-timeout 30 --max-time 300 "$1" -o "$2"
	}
elif command -v wget >/dev/null 2>&1; then
	fetch() {
		wget --https-only --quiet --max-redirect 10 --timeout 300 \
			"$1" -O "$2"
	}
else
	fail "need curl or wget on PATH to fetch the launcher"
fi

shim_source="${CLAUDE_PLUGIN_ROOT}/bin/accelerator-verify-${platform}"
[[ -x "${shim_source}" ]] ||
	fail "verify shim missing for ${platform}: ${shim_source}"
public_key="${CLAUDE_PLUGIN_ROOT}/keys/accelerator-release.pub"
[[ -f "${public_key}" ]] || fail "release public key missing: ${public_key}"

# Probe write AND exec (a noexec mount passes a write-only check but breaks exec).
probe_dir() {
	mkdir -p "$1" 2>/dev/null || return 1
	probe="$1/.accelerator-probe-$$"
	printf '#!/bin/sh\nexit 0\n' >"${probe}" 2>/dev/null || return 1
	chmod +x "${probe}" 2>/dev/null || {
		rm -f "${probe}"
		return 1
	}
	if "${probe}" >/dev/null 2>&1; then
		rm -f "${probe}"
		return 0
	fi
	rm -f "${probe}"
	return 1
}

# ${CLAUDE_PLUGIN_ROOT}/bin or the ACCELERATOR_CACHE_DIR override; no XDG
# fallback (an XDG-resident binary would break the allowed-tools glob match).
resolve_cache_dir() {
	if [[ -n "${ACCELERATOR_CACHE_DIR:-}" ]]; then
		probe_dir "${ACCELERATOR_CACHE_DIR}" || return 1
		printf '%s\n' "${ACCELERATOR_CACHE_DIR}"
		return 0
	fi
	primary="${CLAUDE_PLUGIN_ROOT}/bin"
	probe_dir "${primary}" || return 1
	printf '%s\n' "${primary}"
}

cache_dir=$(resolve_cache_dir) ||
	fail "no writable, exec-capable cache directory: ${CLAUDE_PLUGIN_ROOT}/bin \
is not usable and no ACCELERATOR_CACHE_DIR override was given (no XDG fallback)"

# ── Local-build override (skips fetch, cache and verification entirely) ──────
# Three gates: the opt-in variable, the untracked dev-launcher marker, and a
# named binary that canonically resolves to a non-symlink regular executable
# inside cli/target/. After the migration this path is pre-authorised in 35
# skills and invoked unattended at every SessionStart, so an ambient env var
# alone must not redirect it. Warns and records durably, since stderr is invisible
# at SessionStart and behind the !-site --fail-safe contract.
dev_launcher_marker="${CLAUDE_PLUGIN_ROOT}/.accelerator-dev-launcher"

dev_launcher_contained() {
	bin="$1"
	[[ -e "${bin}" && ! -L "${bin}" && -f "${bin}" && -x "${bin}" ]] || return 1
	target_root=$(cd "${CLAUDE_PLUGIN_ROOT}/cli/target" 2>/dev/null && pwd -P) ||
		return 1
	bin_parent=$(cd "$(dirname "${bin}")" 2>/dev/null && pwd -P) || return 1
	case "${bin_parent}/" in
	"${target_root}/"*) return 0 ;;
	*) return 1 ;;
	esac
}

if [[ "${ACCELERATOR_ALLOW_UNVERIFIED_LAUNCHER:-}" == "1" &&
	-f "${dev_launcher_marker}" && -n "${ACCELERATOR_LAUNCHER_BIN:-}" ]]; then
	dev_launcher_contained "${ACCELERATOR_LAUNCHER_BIN}" ||
		fail "ACCELERATOR_LAUNCHER_BIN refused (not a regular executable inside \
${CLAUDE_PLUGIN_ROOT}/cli/target/): ${ACCELERATOR_LAUNCHER_BIN}"
	printf 'accelerator: WARNING execing unverified launcher: %s\n' \
		"${ACCELERATOR_LAUNCHER_BIN}" >&2
	printf '%s pid=%s %s\n' \
		"$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || printf 'unknown')" \
		"$$" "${ACCELERATOR_LAUNCHER_BIN}" \
		>>"${cache_dir}/.accelerator-unverified.log" 2>/dev/null || true
	exec "${ACCELERATOR_LAUNCHER_BIN}" "$@"
fi

# Portable full-digest sha256 (detection-based backend, matching the repo idiom);
# inlined to keep this root-of-trust entry point self-contained (it sources
# nothing else).
sha256_file() {
	if command -v sha256sum >/dev/null 2>&1; then
		sha256sum "$1" | awk '{print $1}'
	else
		shasum -a 256 "$1" | awk '{print $1}'
	fi
}

# The plugin root may be noexec, so run the shim from the cache dir, and by
# absolute path so a PATH-planted decoy cannot stand in for the verifier.
# Content-addressed by the source shim's own digest: a warm call re-hashes
# (cheap) instead of re-copying 475KB, a uniquely-named file is never torn by a
# concurrent reader, and skip-if-exists verifies the staged bytes against that
# digest so a planted stub is re-staged rather than trusted by name.
shim_digest=$(sha256_file "${shim_source}") ||
	fail "could not hash the verify shim source: ${shim_source}"
shim="${cache_dir}/accelerator-verify-${platform}-${shim_digest}"
if [[ ! -x "${shim}" ]] ||
	[[ "$(sha256_file "${shim}" 2>/dev/null)" != "${shim_digest}" ]]; then
	cp "${shim_source}" "${shim}" 2>/dev/null ||
		fail "could not stage the verify shim into ${cache_dir}"
	chmod +x "${shim}" 2>/dev/null ||
		fail "could not make the verify shim executable"
fi

# Serialise concurrent first-use sessions; a lock orphaned by a SIGKILL'd
# bootstrap (no trap ran) is reclaimed via a PID-owner staleness check.
lock_dir="${cache_dir}/.accelerator-lock-${platform}"
lock_held=""

release_lock() {
	[[ -n "${lock_held}" ]] || return 0
	rm -f "${lock_dir}/pid" 2>/dev/null
	rmdir "${lock_dir}" 2>/dev/null
	lock_held=""
}

acquire_lock() {
	waited=0
	while true; do
		if mkdir "${lock_dir}" 2>/dev/null; then
			printf '%s\n' "$$" >"${lock_dir}/pid" 2>/dev/null
			lock_held=1
			trap release_lock EXIT INT TERM
			return 0
		fi
		owner=$(cat "${lock_dir}/pid" 2>/dev/null)
		if [[ -n "${owner}" ]] && kill -0 "${owner}" 2>/dev/null; then
			# A live owner is fetching, bounded by curl's --max-time; reset the
			# abort budget so a slow-but-progressing cold fetch never fails a
			# waiter. The budget elapses only while no live owner is seen — a
			# dead owner is reclaimed immediately below.
			waited=0
		elif [[ -n "${owner}" ]]; then
			rm -f "${lock_dir}/pid" 2>/dev/null
			rmdir "${lock_dir}" 2>/dev/null
			continue
		else
			waited=$((waited + 1))
			if [[ "${waited}" -gt 300 ]]; then
				fail "timed out acquiring the launcher cache lock: ${lock_dir}"
			fi
		fi
		sleep 0.1
	done
}

launcher="${cache_dir}/accelerator-launcher-${version}-${platform}"
launcher_sig="${launcher}.minisig"
base_url="${ACCELERATOR_RELEASE_BASE_URL:-https://github.com/atomicinnovation/accelerator/releases/download/v${version}}"

# Fail-closed: a bad signature OR an unrunnable shim both mean "not verified".
verify_launcher() {
	"${shim}" "${public_key}" "${launcher_sig}" "${launcher}" >/dev/null 2>&1
}

# Fetch and verify into temp files, renaming a verified successor over any
# corrupt entry only once it exists (never evict before a replacement is ready).
fetch_and_verify() {
	tmp_bin="${cache_dir}/.tmp-launcher-$$"
	tmp_sig="${tmp_bin}.minisig"
	if ! fetch "${base_url}/accelerator-${platform}" "${tmp_bin}"; then
		rm -f "${tmp_bin}"
		return 1
	fi
	if ! fetch "${base_url}/accelerator-${platform}.minisig" "${tmp_sig}"; then
		rm -f "${tmp_bin}" "${tmp_sig}"
		return 1
	fi
	chmod +x "${tmp_bin}" 2>/dev/null
	if ! "${shim}" "${public_key}" "${tmp_sig}" "${tmp_bin}" \
		>/dev/null 2>&1; then
		rm -f "${tmp_bin}" "${tmp_sig}"
		return 1
	fi
	mv "${tmp_sig}" "${launcher_sig}" && mv "${tmp_bin}" "${launcher}"
}

if [[ -x "${launcher}" ]] && [[ -f "${launcher_sig}" ]] && verify_launcher; then
	: # cache hit — reuse without a lock or fetch
else
	acquire_lock
	# Re-check under the lock in case another session populated the cache.
	if ! { [[ -x "${launcher}" ]] && [[ -f "${launcher_sig}" ]] &&
		verify_launcher; }; then
		fetch_and_verify ||
			fail "could not fetch and verify the accelerator launcher for \
${platform}"
	fi
	release_lock
fi

# argv list (no shell-string interpolation); CLAUDE_PLUGIN_ROOT stays in the env
# so the launcher resolves the same cache root for its sub-binaries.
exec "${launcher}" "$@"
